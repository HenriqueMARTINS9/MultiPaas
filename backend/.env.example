DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CORS_ALLOW_ALL_ORIGINS=1

# PostgreSQL (default)
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=multipaas
DJANGO_DB_USER=multipaas
DJANGO_DB_PASSWORD=multipaas
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5433
DJANGO_DB_CONN_MAX_AGE=60
# Optional single-URL DB config (takes precedence if set):
# DATABASE_URL=postgres://user:password@host:5432/database

# Set sqlite fallback if needed:
# DJANGO_DB_ENGINE=sqlite

# Stancer
STANCER_API_BASE_URL=https://api.stancer.com
STANCER_PRIVATE_KEY=
STANCER_PUBLIC_KEY=
STANCER_RETURN_URL=http://127.0.0.1:3000/billing
